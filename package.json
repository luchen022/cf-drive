{
  "name": "cf-drive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:frontend": "node scripts/build-frontend.js",
    "build": "npm run build:frontend && wrangler deploy --dry-run --outdir dist",
    "dev": "npm run build:frontend && wrangler dev --local",
    "deploy": "npm run build:frontend && wrangler deploy",
    "test": "vitest --run",
    "db:init": "wrangler d1 execute cf-drive-db --local --file=./migrations/001_init.sql",
    "db:query": "wrangler d1 execute cf-drive-db --local --command",
    "db:reset": "rm -rf .wrangler/state/ && npm run db:init"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240725.0",
    "fast-check": "^3.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.65.0"
  }
}
